generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model AdminUser {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Project {
  id               String        @id @default(cuid())
  title            String
  slug             String        @unique
  shortDescription String
  description      String?
  imageUrl         String?
  techStack        String[]
  githubUrl        String?
  liveUrl          String?
  featured         Boolean       @default(false)
  status           ProjectStatus @default(DRAFT)
  order            Int           @default(0)
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
}

model Credential {
  id                    String               @id
  slug                  String               @unique
  type                  CredentialType       @default(CERTIFICATE)
  sourceType            CredentialSourceType @default(DRAFT_FILE)
  title                 String
  officialTitle         String?
  category              String
  subCategory           String?
  issuer                String
  issuerType            String?
  certificateNumber     String?
  participantName       String               @default("Syah Putra Nugraha")
  issueDate             DateTime?
  originalIssueDate     String?
  startDate             DateTime?
  originalStartDate     String?
  endDate               DateTime?
  originalEndDate       String?
  duration              String?
  status                String?
  grade                 String?
  level                 String?
  skills                String[]
  relatedTech           String[]
  relatedDomains        String[]
  competencies          Json?
  keyTopics             Json?
  summary               String
  portfolioRelevance    String
  recruiterValue        String?
  displayPriority       Int                  @default(3)
  featured              Boolean              @default(false)
  showOnHomepage        Boolean              @default(false)
  showOnCertificatePage Boolean              @default(true)
  driveUrl              String?
  fileName              String?
  language              String?
  notes                 String?
  metadata              Json?
  verificationStatus    VerificationStatus   @default(NEEDS_MANUAL_VERIFICATION)
  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @updatedAt
  featuredHighlight     FeaturedCredential?

  @@index([category])
  @@index([featured])
  @@index([displayPriority])
  @@index([verificationStatus])
  @@index([type])
  @@index([sourceType])
}

model FeaturedCredential {
  id           String     @id @default(cuid())
  credentialId String     @unique
  priority     Int        @default(1)
  reason       String?
  credential   Credential @relation(fields: [credentialId], references: [id], onDelete: Cascade)
}

model Skill {
  id          String    @id @default(cuid())
  name        String
  type        SkillType @default(TECHNICAL)
  category    String?
  icon        String?
  level       String?
  description String?
  order       Int       @default(0)
  visible     Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([name, type])
}

model Experience {
  id          String           @id @default(cuid())
  role        String
  company     String
  location    String?
  type        String?
  startDate   DateTime?
  endDate     DateTime?
  isCurrent   Boolean          @default(false)
  description String?
  highlights  String[]
  techStack   String[]
  status      ExperienceStatus @default(DRAFT)
  order       Int              @default(0)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
}

model Education {
  id          String   @id @default(cuid())
  school      String
  degree      String
  period      String
  description String?
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model SiteSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum ProjectStatus {
  DRAFT
  PUBLISHED
}

enum CredentialType {
  CERTIFICATE
  SUPPORTING_DOCUMENT
}

enum VerificationStatus {
  VERIFIED
  NEEDS_MANUAL_VERIFICATION
  UNVERIFIED
}

enum CredentialSourceType {
  DRAFT_FILE
  GOOGLE_DRIVE
  MANUAL_INPUT
  CMS
}

enum SkillType {
  TECHNICAL
  SOFT
  TOOL
  LANGUAGE
}

enum ExperienceStatus {
  DRAFT
  PUBLISHED
}
