// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// --------------------------------------
// Authentication
// --------------------------------------

model AdminUser {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// --------------------------------------
// Projects
// --------------------------------------

model Project {
  id               String        @id @default(cuid())
  title            String
  slug             String        @unique
  shortDescription String
  description      String?
  imageUrl         String?
  techStack        String[]
  githubUrl        String?
  liveUrl          String?
  featured         Boolean       @default(false)
  status           ProjectStatus @default(DRAFT)
  order            Int           @default(0)
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
}

enum ProjectStatus {
  DRAFT
  PUBLISHED
}

// --------------------------------------
// Credentials & Certifications (REFACTORED)
// --------------------------------------

enum CredentialType {
  CERTIFICATE
  SUPPORTING_DOCUMENT
}

enum VerificationStatus {
  VERIFIED
  NEEDS_MANUAL_VERIFICATION
  UNVERIFIED
}

enum CredentialSourceType {
  DRAFT_FILE
  GOOGLE_DRIVE
  MANUAL_INPUT
  CMS
}

model Credential {
  id                String               @id
  slug              String               @unique
  type              CredentialType       @default(CERTIFICATE)
  sourceType        CredentialSourceType @default(DRAFT_FILE)
  
  title             String
  officialTitle     String?
  category          String
  subCategory       String?
  issuer            String
  issuerType        String?
  certificateNumber String?
  participantName   String               @default("Syah Putra Nugraha")
  
  // Dates: DateTime for logic, Original for context
  issueDate         DateTime?
  originalIssueDate String?
  startDate         DateTime?
  originalStartDate String?
  endDate           DateTime?
  originalEndDate   String?
  duration          String?
  
  status            String?
  grade             String?
  level             String?
  
  // Hybrid Array Strategy
  skills            String[]       // Canonical Names (e.g., "React", "Node.js")
  relatedTech       String[]
  relatedDomains    String[]
  
  // Content
  competencies      Json?          
  keyTopics         Json?          
  summary           String         @db.Text
  portfolioRelevance String        @db.Text
  recruiterValue    String?        @db.Text
  
  // Visibility & Ranking
  displayPriority   Int            @default(3)
  featured          Boolean        @default(false)
  showOnHomepage    Boolean        @default(false)
  showOnCertificatePage Boolean    @default(true)
  
  // Assets & Documentation
  driveUrl          String?
  fileName          String?
  language          String?        // "Indonesian", "English", or null
  
  // Internal Tracking
  notes             String?        @db.Text
  metadata          Json?          // For future complex metadata
  verificationStatus VerificationStatus @default(NEEDS_MANUAL_VERIFICATION)

  // Relations
  featuredHighlight FeaturedCredential?

  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  @@index([category])
  @@index([featured])
  @@index([displayPriority])
  @@index([verificationStatus])
  @@index([type])
  @@index([sourceType])
}

model FeaturedCredential {
  id           String     @id @default(cuid())
  credentialId String     @unique
  priority     Int        @default(1)
  reason       String?    @db.Text
  
  credential   Credential @relation(fields: [credentialId], references: [id], onDelete: Cascade)
}

// --------------------------------------
// Skills & Experience
// --------------------------------------

enum SkillType {
  TECHNICAL
  SOFT
  TOOL
  LANGUAGE
}

model Skill {
  id          String    @id @default(cuid())
  name        String
  type        SkillType @default(TECHNICAL)
  category    String?
  icon        String?
  level       String?
  description String?
  order       Int       @default(0)
  visible     Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([name, type])
}

model Experience {
  id          String           @id @default(cuid())
  role        String
  company     String
  location    String?
  type        String?
  startDate   DateTime?
  endDate     DateTime?
  isCurrent   Boolean          @default(false)
  description String?
  highlights  String[]
  techStack   String[]
  status      ExperienceStatus @default(DRAFT)
  order       Int              @default(0)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
}

enum ExperienceStatus {
  DRAFT
  PUBLISHED
}

// --------------------------------------
// Education & Others
// --------------------------------------

model Education {
  id          String   @id @default(cuid())
  school      String
  degree      String
  period      String
  description String?
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model SiteSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
