// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model AdminUser {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Project {
  id               String        @id @default(cuid())
  title            String
  slug             String        @unique
  shortDescription String
  description      String?
  imageUrl         String?
  techStack        String[]
  githubUrl        String?
  liveUrl          String?
  featured         Boolean       @default(false)
  status           ProjectStatus @default(DRAFT)
  order            Int           @default(0)
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
}

enum ProjectStatus {
  DRAFT
  PUBLISHED
}

model SiteSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum SkillType {
  TECHNICAL
  SOFT
  TOOL
  LANGUAGE
}

model Skill {
  id          String    @id @default(cuid())
  name        String
  type        SkillType @default(TECHNICAL)
  category    String?
  icon        String?
  level       String?
  description String?
  order       Int       @default(0)
  visible     Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([name, type])
}

model Experience {
  id          String           @id @default(cuid())
  role        String
  company     String
  location    String?
  type        String?
  startDate   DateTime?
  endDate     DateTime?
  isCurrent   Boolean          @default(false)
  description String?
  highlights  String[]
  techStack   String[]
  status      ExperienceStatus @default(DRAFT)
  order       Int              @default(0)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
}

enum ExperienceStatus {
  DRAFT
  PUBLISHED
}

enum CertificationType {
  PROFESSIONAL
  TECHNICAL
  ACADEMIC
  TRAINING
  SOFT_SKILL
  EVENT
  OTHER
}

enum CertificationStatus {
  DRAFT
  PUBLISHED
}

model Certification {
  id             String              @id @default(cuid())
  title          String
  issuer         String
  type           CertificationType   @default(TRAINING)
  category       String?
  credentialId   String?
  credentialUrl  String?
  certificateUrl String?
  driveUrl       String?
  imageUrl       String?
  issuedAt       DateTime?
  expiredAt      DateTime?
  doesNotExpire  Boolean             @default(true)
  skills         String[]
  description    String?
  featured       Boolean             @default(false)
  status         CertificationStatus @default(DRAFT)
  order          Int                 @default(0)
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
}

model Education {
  id          String   @id @default(cuid())
  school      String
  degree      String
  period      String
  description String?
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

